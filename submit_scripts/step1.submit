#Analysis Processing

executable = /data/user/akatil/electron_neutrino/for_real/analysis_chain/submit_scripts/step1.sh

interaction = $(INTERACTION)
dataset = $(DATASET)

log = /scratch/akatil/electron_neutrino/step1_processing_$(interaction)_$(dataset).log
output = /data/user/akatil/electron_neutrino/for_real/logFiles/step1/step1_processing_$(interaction)_$(dataset).out
